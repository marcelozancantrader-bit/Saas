# =============================================
# Memorial.ai — Environment variables
# Copy to .env.local and fill in the values.
# .env.local is gitignored. NEVER commit real secrets.
# =============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase (Sprint 1) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres URL for supabase CLI (db push). Format:
# postgresql://postgres.<project-ref>:<password>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# ---- Auth (Sprint 1) ----
# Toggle Google OAuth button. Keep false until Google Cloud OAuth client is configured.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# ---- AI (Sprint 3+) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Email (Sprint 6+) ----
# Sign up at https://resend.com — 100 e-mails/dia free
RESEND_API_KEY=
# Ex: "Memorial.ai <portal@seudominio.com>" — domínio deve estar verificado na Resend
RESEND_FROM_EMAIL=

# ---- Billing (Sprint 7+) ----
# Asaas — cobrança PIX/boleto/cartão. Conta sandbox grátis em:
#   https://www.asaas.com/sandbox
# 1) Cria conta sandbox → painel → Integrações → Gerar API Key
# 2) Define ASAAS_WEBHOOK_TOKEN como um valor aleatório forte (ex: openssl rand -hex 32)
# 3) No painel Asaas → Notificações → Webhook → adiciona
#    URL: https://<seu-dominio>/api/webhooks/asaas
#    Token: o mesmo valor de ASAAS_WEBHOOK_TOKEN
#    Eventos: PAYMENT_RECEIVED, PAYMENT_OVERDUE, PAYMENT_REFUNDED,
#             SUBSCRIPTION_DELETED, SUBSCRIPTION_UPDATED
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
# "sandbox" (default) ou "production". Apenas mude para "production" quando
# a conta sandbox estiver validada e você tiver a API key da conta real.
ASAAS_ENVIRONMENT=sandbox

# ---- Jobs (Sprint 3+) ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Observability (Sprint 8) ----
POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Captcha (signup anti-bot) ----
# Cloudflare Turnstile — grátis, sem limite.
# 1) https://dash.cloudflare.com → Turnstile → Add site
# 2) Mode: "Managed" (recomendado) ou "Invisible"
# 3) Copia site key (publica) e secret key (server only)
# Sem essas envs, o widget não renderiza e a validação server-side é pulada.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
