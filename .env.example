# =============================================
# Memorial.ai — Environment variables
# Copy to .env.local and fill in the values.
# .env.local is gitignored. NEVER commit real secrets.
# =============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase (Sprint 1) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres URL for supabase CLI (db push). Format:
# postgresql://postgres.<project-ref>:<password>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# ---- Auth (Sprint 1) ----
# Toggle Google OAuth button. Keep false until Google Cloud OAuth client is configured.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# ---- AI (Sprint 3+) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Email (Sprint 6+) ----
RESEND_API_KEY=

# ---- Billing (Sprint 7+) ----
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=

# ---- Jobs (Sprint 3+) ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Observability (Sprint 8) ----
POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
